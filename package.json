{
  "name": "glyphrame",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @glyphrame/web dev",
    "build": "bun run --filter @glyphrame/web build",
    "preview": "bun run --filter @glyphrame/web preview",
    "typecheck:tooling": "tsc -p tsconfig.tooling.json --noEmit",
    "typecheck": "bun run typecheck:tooling && bun run --filter @glyphrame/schemas typecheck && bun run --filter @glyphrame/engine typecheck && bun run --filter @glyphrame/web typecheck",
    "test:unit": "bunx --bun vitest run",
    "test:unit:watch": "bunx --bun vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/node": "^24.0.0",
    "@webgpu/types": "^0.1.64",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
